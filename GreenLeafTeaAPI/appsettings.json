{
  "_README": "Override ConnectionStrings and Jwt:Key in appsettings.Development.json or via environment variables (JWT_SECRET_KEY).",
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=GreenLeafTeaDB;user=root;password=YOUR_DB_PASSWORD;SslMode=None;"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_A_SECURE_KEY_AT_LEAST_32_CHARACTERS_LONG",
